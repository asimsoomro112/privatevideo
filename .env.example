# ===========================================
# PrivateVideos Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# Supabase/PostgreSQL database.
# DATABASE_URL: use Supabase Transaction Pooler / pooler URL for app runtime.
# DIRECT_URL: use Supabase direct connection URL for Prisma schema pushes.
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
# Local dev can stay localhost. On Vercel, set this to your deployed URL
# or leave it unset; the app will trust Vercel's host automatically.
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Single private password for the girlfriend login.
PRIVATE_ACCESS_PASSWORD="change-this-password"

BUNNY_STREAM_LIBRARY_ID="your-bunny-stream-library-id"
BUNNY_STREAM_ACCESS_KEY="your-bunny-stream-api-key"
BUNNY_STREAM_HOSTNAME="your-bunny-cdn-hostname.b-cdn.net"

# Brand configuration.
NEXT_PUBLIC_SITE_NAME="PrivateVideos"
